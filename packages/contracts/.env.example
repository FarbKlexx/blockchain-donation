# Hardhat 3 hat KEINEN eingebauten .env-Loader.
# configVariable("NAME") liest per Default aus echten Umgebungsvariablen und,
# falls vorhanden, aus dem verschluesselten Keystore (Keystore hat Vorrang).
#
# Empfohlen (lokal): Werte verschluesselt im Keystore ablegen, NICHT in einer .env:
#   npx hardhat keystore set SEPOLIA_RPC_URL
#   npx hardhat keystore set SEPOLIA_PRIVATE_KEY
#
# In CI wird der Keystore umgangen -> dort die Werte als Umgebungsvariablen setzen.
# Diese Datei ist nur Referenz/Doku. (.env/.env.* sind via .gitignore ausgenommen.)

SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=
