# Node modules
/node_modules

# Compilation output
/dist

# pnpm deploy output
/bundle

# Hardhat Build Artifacts
/artifacts

# Hardhat compilation (v2) support directory
/cache

# Typechain output
/types

# Hardhat Ignition deployment artifacts (generated per network: journal,
# deployed addresses, build-info, contract artifacts). Local chains are
# throwaway; un-ignore a specific network dir if you want to track its
# deployed addresses (e.g. a public testnet/mainnet).
/ignition/deployments

# Environment files
.env
.env.*
!.env.example

# Hardhat coverage reports
/coverage

# Gas snapshot files
/.gas-snapshot

# Snapshot cheatcodes output
/snapshots
