# Frontend-Konfiguration. Vite liest VITE_*-Variablen und backt sie ins
# Client-Bundle. .env aus dieser Vorlage erstellen:  cp .env.example .env

# Lokale Hardhat-Node
VITE_RPC_URL=http://127.0.0.1:8545

# Hardhat-TEST-Private-Key. Vorbelegt mit Account #0 aus `npx hardhat node`
# (Mnemonic "test test ... junk"). ACHTUNG: oeffentlich bekannter Test-Key, landet
# im Client-Bundle -> NIEMALS einen echten/finanzierten Key hier eintragen.
VITE_DEV_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Adresse des deployten Contracts (Ausgabe von `npm run deploy:local`/`deploy:sepolia`).
VITE_CONTRACT_ADDRESS=

# Backend-API
VITE_API_BASE_URL=http://127.0.0.1:5000
